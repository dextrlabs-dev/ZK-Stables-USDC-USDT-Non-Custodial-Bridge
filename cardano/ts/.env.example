# Blockfrost (Preprod project id typical). Leave empty when using YACI_URL (Yaci-only local dev).
BLOCKFROST_PROJECT_ID=

# Yaci DevKit provider (local devnet)
# If YACI_URL is set, cardano/ts uses YaciProvider instead of BlockfrostProvider (Blockfrost not used).
YACI_URL=http://127.0.0.1:8080/api/v1
# Optional admin endpoint (topup, devnet actions). Leave empty if not used.
YACI_ADMIN_URL=http://127.0.0.1:10000

# 0 = testnets (Preprod), 1 = mainnet
CARDANO_NETWORK_ID=0

# Comma-separated mnemonic (quotes optional)
CARDANO_WALLET_MNEMONIC=

# Mesh network label for TxBuilder
CARDANO_MESH_NETWORK=preprod

# Registry / unlock_pool: payment credential hash of operator (28 bytes = 56 hex chars)
REGISTRY_OPERATOR_VKEY_HASH=
