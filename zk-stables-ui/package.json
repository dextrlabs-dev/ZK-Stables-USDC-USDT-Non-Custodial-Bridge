{
  "name": "@zk-stables/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "copy-zk-artifacts": "node scripts/copy-zk-artifacts.mjs",
