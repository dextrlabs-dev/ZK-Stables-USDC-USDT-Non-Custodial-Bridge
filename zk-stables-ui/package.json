{
  "name": "@zk-stables/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-zk-artifacts": "node scripts/copy-zk-artifacts.mjs",
    "sync-cardano-units": "node scripts/sync-cardano-native-units.mjs",
    "dev": "npm run copy-zk-artifacts && vite",
    "dev:fresh": "rm -rf node_modules/.vite && npm run copy-zk-artifacts && vite",
    "build": "npm run copy-zk-artifacts && tsc --noEmit && vite build --mode development",
    "build:prod": "npm run copy-zk-artifacts && tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "start": "npm run build && vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc -b --noEmit",
    "verify:bridge-locks": "node --env-file=.env.production scripts/verify-bridge-lock-discovery.mjs",
    "verify:discover-parity": "node --env-file=.env.production scripts/verify-discover-parity.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@meshsdk/common": "^1.8.14",
    "@meshsdk/core": "^1.8.14",
    "@midnight-ntwrk/compact-js": "2.5.0",
    "@midnight-ntwrk/compact-runtime": "0.15.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "4.0.2",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "4.0.2",
    "@midnight-ntwrk/midnight-js-types": "4.0.2",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnight-ntwrk/wallet-sdk-facade": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@scure/bip39": "^2.0.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@tanstack/react-query": "^5.95.2",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "pino": "^10.1.0",
    "process": "^0.11.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.3",
    "rxjs": "^7.8.1",
    "stream-browserify": "^3.0.0",
    "viem": "^2.47.6",
    "wagmi": "^3.6.0"
  },
  "devDependencies": {
    "@rollup/plugin-inject": "^5.0.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.27",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1"
  }
}
