# Optional: Cardano Blockfrost (Preprod or Mainnet project id from https://blockfrost.io)
# Never commit real keys — copy to .env locally.
# RELAYER_BLOCKFROST_PROJECT_ID=
# RELAYER_BLOCKFROST_NETWORK=preprod

# EVM: burn → Merkle proof → unlock (see zk/README.md)
# RELAYER_EVM_POOL_LOCK=
# RELAYER_EVM_UNDERLYING_TOKEN=
# RELAYER_EVM_WRAPPED_TOKEN=
# RELAYER_EVM_CONFIRMATIONS=1
# RELAYER_EVM_PRIVATE_KEY=
