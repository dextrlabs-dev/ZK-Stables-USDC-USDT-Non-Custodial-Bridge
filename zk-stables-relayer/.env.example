# Midnight indexer HTTP URL for /v1/health/chains (default is v4; set v3 if your stack uses api/v3 only)
# RELAYER_MIDNIGHT_INDEXER_URL=http://127.0.0.1:8088/api/v4/graphql

# Cardano indexer (use one path)
# Local Yaci Store (Blockfrost-compatible API). If RELAYER_YACI_URL or YACI_URL is set, the relayer
# uses Yaci only for Cardano health, lock watcher, and finality — Blockfrost is ignored for Cardano.
# RELAYER_YACI_URL=http://127.0.0.1:8080/api/v1
# (fallback when RELAYER_YACI_URL unset: same-name YACI_URL from your shell / cardano/ts .env)
#
# Optional: Blockfrost (Preprod or Mainnet) when no Yaci URL is set
# RELAYER_BLOCKFROST_PROJECT_ID=
# RELAYER_BLOCKFROST_NETWORK=preprod

# EVM: which synthetic USD label burn watcher attaches (USDC vs USDT mock wrapped token)
# RELAYER_EVM_BURN_ASSET=USDC

# EVM: burn → Merkle proof → unlock (see zk/README.md)
# RELAYER_EVM_POOL_LOCK=
# RELAYER_EVM_UNDERLYING_TOKEN=
# RELAYER_EVM_WRAPPED_TOKEN=
# RELAYER_EVM_CONFIRMATIONS=1
# RELAYER_EVM_PRIVATE_KEY=

# Bridge operator payout wallets (optional defaults + echo on `intent.connected.relayerBridge`)
# RELAYER_BRIDGE_EVM_RECIPIENT=0x...
# RELAYER_BRIDGE_CARDANO_RECIPIENT=addr1...   # or hex payment cred from CIP-30
# RELAYER_BRIDGE_MIDNIGHT_RECIPIENT=mn_addr... # fallback when RELAYER_CARDANO_RECIPIENT_STUB is unset (Cardano lock watcher)
